# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API key (reserved for Phase 2 - not used yet)
ANTHROPIC_API_KEY=

# Your OWN numeric Telegram id (an integer, e.g. 123456789), NOT the bot @username
# and NOT the bot id (the number before ":" in the token). Message @userinfobot,
# or run the bot and check the console log. Only messages from this chat are accepted.
ALLOWED_CHAT_ID=

# SQLAlchemy database URL (default: local SQLite file)
DATABASE_URL=sqlite:///organizer.db

# Folder of the Obsidian vault to export into (Phase 4)
VAULT_PATH=vault

# Semantic memory (Phase 5): local sentence-transformers model.
# SIMILARITY_THRESHOLD: above it, a new entry suggests a connection.
# SEARCH_THRESHOLD: below it, a semantic "related" result in /buscar is dropped.
# SEARCH_RERANK: true = /buscar uses Claude Haiku to filter candidates by meaning
#   (e.g. "sair" also finds "cinema com a Helen"); false = local hybrid only (free).
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SIMILARITY_THRESHOLD=0.6
SEARCH_THRESHOLD=0.45
SEARCH_RERANK=true

# Weekly review / insights (Phase 6): Claude Sonnet analyzes the week.
# INSIGHTS_MODEL: model used by /review.
# TIMEZONE: IANA name used to schedule the automatic review.
# REVIEW_AUTO_ENABLED: send a weekly review by itself once the trigger is met.
# REVIEW_WEEKDAY (0=Mon..6=Sun) + REVIEW_HOUR: when the automatic review fires.
# REVIEW_MIN_ENTRIES / REVIEW_MIN_WEEKS: proactivity trigger (200+ entries OR 4+ weeks).
INSIGHTS_MODEL=claude-sonnet-5
TIMEZONE=America/Campo_Grande
REVIEW_AUTO_ENABLED=true
REVIEW_WEEKDAY=6
REVIEW_HOUR=20
REVIEW_MIN_ENTRIES=200
REVIEW_MIN_WEEKS=4

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
